{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "视频解析下载",
  "version": "0.1.0",
  "identifier": "com.video-downloader.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "视频解析下载",
        "width": 1100,
        "height": 720,
        "minWidth": 860,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "template": "nsis-template.nsi"
      }
    },
    "externalBin": [
      "binaries/python-backend"
    ]
  }
}
